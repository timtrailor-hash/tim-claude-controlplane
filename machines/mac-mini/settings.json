{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__memory",
      "mcp__claude_ai_Databricks_SQL_MCP__execute_sql_read_only",
      "mcp__claude_ai_Databricks_SQL_MCP__execute_sql"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/Users/timtrailor/code"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/validate_hooks.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "MEM=\"\"; for p in /Users/timtrailor/.claude/projects/-Users-timtrailor-Documents-Claude-code/memory /Users/timtrailor/.claude/projects/-Users-timtrailor-code/memory; do [ -d \"/.git\" ] && MEM=\"\" && break; done; [ -z \"\" ] && exit 0; cd \"\" && git stash -q 2>/dev/null; git pull --rebase origin main 2>/tmp/claude_git_pull.log; PULL_RC=0; git stash pop -q 2>/dev/null || git checkout --theirs . 2>/dev/null && git stash drop -q 2>/dev/null; [  -ne 0 ] && (git rebase --abort 2>/dev/null; echo \"Memory pull failed\" | curl -s -d @- ntfy.sh/timtrailor-claude 2>/dev/null); exit 0",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/memory_health_check.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/memory_sync_pull.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/auto_review_hook.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/drift_check_trigger.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/memory_sync_push.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/code/auto_index.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/memory_commit_push.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "curl -s -d 'Claude session ended' ntfy.sh/timtrailor-claude 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/protected_path_hook.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/printer-safety-check.sh",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/rename_guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/commit_guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/credential_leak_hook.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/credential_leak_hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/audit_log_hook.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/lint_hook.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/session_manifest_hook.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/lint_hook.sh",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/session_manifest_hook.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/la_turn_hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/timtrailor/.claude/hooks/la_turn_hook.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "memory": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/python3.11",
      "args": [
        "/Users/timtrailor/code/memory_server.py"
      ]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "/Users/timtrailor/code",
        "/Users/timtrailor/.claude"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@2.1.8"
      ]
    },
    "serena": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "/Users/timtrailor/.claude/mcp-launchers/github-mcp.sh"
    }
  },
  "skipDangerousModePermissionPrompt": true
}

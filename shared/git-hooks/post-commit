#!/bin/bash
# post-commit — log whether pre-commit was bypassed or run in advisory mode.
#
# This can't BLOCK --no-verify (by definition, --no-verify skips hooks),
# but it catches the ADVISORY-mode case and leaves an audit trail of recent
# commits so Tim's Monday digest can flag bypass patterns.
#
# Bypass detection is best-effort. The only reliable signals:
#   1. GIT_HOOKS_MODE=advisory set during commit  (we see it)
#   2. Commit trailer `Ratchet-override:` present
#   3. Commit message contains `#no-verify` marker
# --no-verify itself is invisible to post-commit.

AUDIT="$HOME/code/commit_audit.log"
mkdir -p "$(dirname "$AUDIT")"

SHA=$(git rev-parse HEAD 2>/dev/null || echo "?")
REPO=$(git rev-parse --show-toplevel 2>/dev/null | xargs -I {} basename {} 2>/dev/null || echo "?")
MSG=$(git log -1 --format=%B HEAD 2>/dev/null || echo "")

reason=""
if [ "${GIT_HOOKS_MODE:-}" = "advisory" ]; then
    reason="advisory-mode"
fi
if echo "$MSG" | grep -qE '^Ratchet-override:'; then
    reason="${reason:+$reason+}ratchet-override"
fi
if echo "$MSG" | grep -q '#no-verify'; then
    reason="${reason:+$reason+}no-verify-marker"
fi

if [ -n "$reason" ]; then
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    echo "{\"timestamp\":\"$ts\",\"repo\":\"$REPO\",\"sha\":\"$SHA\",\"reason\":\"$reason\"}" >> "$AUDIT"
fi

exit 0
